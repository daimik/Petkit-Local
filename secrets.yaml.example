# Copy to secrets.yaml and fill in your own values.
# Never commit secrets.yaml to git!

wifi_ssid: "YourWiFiName"
wifi_password: "YourWiFiPassword"

# Generate a new key: https://esphome.io/components/api.html#configuration-variables
api_encryption_key: "GENERATE_YOUR_OWN_BASE64_KEY_HERE"

# Any random string/hex for OTA updates
ota_password: "GENERATE_YOUR_OWN_OTA_PASSWORD"

# Password for the fallback hotspot (standalone config)
ap_password: "ChooseAFallbackApPassword"
